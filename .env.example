# API base URL (required in production). Example for Vercel-deployed API:
# VITE_API_BASE_URL=https://your-api.vercel.app

# Offline mode: when true, product add/edit and POS sales save locally and sync when back online.
# Set to true for full offline-capable warehouse POS.
VITE_OFFLINE_ENABLED=true

# Optional: rollout percentage 0-100 when VITE_OFFLINE_ENABLED=true (default 100).
# VITE_OFFLINE_ROLLOUT_PERCENT=100
