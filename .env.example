# API (required for production; use .env.local for local dev)
# VITE_API_BASE_URL=http://localhost:3001
# Production: set to your deployed API URL (e.g. https://your-api.vercel.app)

# Supabase (optional; for product images and Realtime)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Sentry (optional; frontend error reporting and source map upload)
# VITE_SENTRY_DSN=           # Frontend DSN from Sentry project settings
# VITE_APP_ENV=development   # production | staging | development (for Sentry environment tag)
# SENTRY_AUTH_TOKEN=         # For source map upload (CI only; add to .gitignore if stored locally)
# SENTRY_ORG=                # Sentry org slug (for source map upload)
# SENTRY_PROJECT=            # Sentry project slug (for source map upload)
