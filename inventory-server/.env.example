# Supabase (required for inventory-server)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis — dashboard stats cache (optional; if missing, cache is disabled)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry (optional; API error reporting and source map upload)
# SENTRY_DSN=                    # Backend DSN from Sentry project settings
# SENTRY_AUTH_TOKEN=             # For source map upload (CI only)
# SENTRY_ORG=                    # Sentry org slug (for source map upload)
# SENTRY_PROJECT=                # Sentry project slug (for source map upload)
# APP_ENV=development            # production | staging | development (for Sentry environment tag)
