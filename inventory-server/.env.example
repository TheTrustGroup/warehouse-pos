# Supabase (required for API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Session / JWT (required for login; min 16 chars)
SESSION_SECRET=your-min-16-char-secret
# Alternative name some setups use:
# JWT_SECRET=your-min-16-char-secret

# Admin / super-admin emails (optional; comma-separated)
# If unset, fallback admin list may be used (see code).
ADMIN_EMAILS=admin@example.com
SUPER_ADMIN_EMAILS=super@example.com

# User scope fallback when user_scopes table is empty (optional)
# Comma-separated warehouse UUIDs.
# ALLOWED_WAREHOUSE_IDS=uuid1,uuid2

# CORS (optional)
# ALLOWED_ORIGINS=https://app.example.com
# ALLOWED_ORIGIN_SUFFIXES=example.com

# For custom JWT verification (optional)
# SALES_JWT_SECRET=optional-separate-jwt-secret
# NEXT_PUBLIC_SUPABASE_URL= same as SUPABASE_URL if frontend needs it
